{
  "name": "vue3-template",
  "type": "module",
  "author": "Jianvey <Jianvey@outlook.com> (https://daixu.cn/)",
  "engines": {
    "node": ">=24.14.0"
  },
  "scripts": {
    "start": "vite",
    "preview": "vite preview",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "type-check": "vue-tsc --build --force",
    "lint": "eslint . --fix",
    "prettier": "prettier --write .",
    "commit": "git-cz",
    "husky-install": "npx husky init && echo \"npm run prettier && npm run lint\" > .husky/pre-commit && echo \"npx --no -- commitlint --edit \\$1\" > .husky/commit-msg",
    "prepare": "husky"
  },
  "dependencies": {
    "@formkit/auto-animate": "^0.9.0",
    "@tailwindcss/vite": "^4.2.1",
    "axios": "^1.13.6",
    "dayjs": "^1.11.20",
    "echarts": "^6.0.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "radash": "^12.1.1",
    "tailwindcss": "^4.2.1",
    "vite-svg-loader": "^5.1.1",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-i18n": "^11.3.0",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.4",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/cz-commitlint": "^20.4.4",
    "@commitlint/prompt-cli": "^20.4.4",
    "@mdi/js": "^7.4.47",
    "@rushstack/eslint-patch": "^1.16.1",
    "@tsconfig/node20": "^20.1.9",
    "@types/node": "^25.5.0",
    "@types/nprogress": "^0.2.3",
    "@vitejs/plugin-legacy": "^8.0.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-prettier": "^10.2.0",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "commitizen": "^4.3.1",
    "eslint": "^10.0.3",
    "eslint-plugin-vue": "^10.8.0",
    "husky": "^9.1.7",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "sass-embedded": "^1.98.0",
    "typescript": "^5.9.3",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^8.0.0",
    "vite-plugin-compression": "^0.5.1",
    "vite-plugin-html": "^3.2.2",
    "vite-plugin-progress": "^0.0.7",
    "vite-plugin-vuetify": "^2.1.3",
    "vue-tsc": "3.2.5",
    "vuetify": "^4.0.2"
  }
}
