{
  "extends": "@vue/tsconfig/tsconfig.dom.json",
  "include": ["vite.config.ts", "*.d.ts", "src/**/*", "config"],
  "exclude": ["src/**/__tests__/*"],
  "compilerOptions": {
    "composite": true,
    "noImplicitAny": false,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "target": "ESNext",
    "lib": ["ESNext", "DOM"],

    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/*"]
    }
  }
}
